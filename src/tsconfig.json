{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowJs": true,
        "checkJs": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "useDefineForClassFields": true,
        "lib": ["ES2020", "DOM", "DOM.Iterable"]
    },
    "include": ["**/*.ts", "**/*.svelte"]
}
