{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OdooCARE",
  "version": "1.0.0",
  "identifier": "com.odoocare.analyzer",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../src",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../src",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "OdooCARE",
        "width": 1280,
        "height": 850,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.svg"
    ],
    "publisher": "OdooCARE",
    "copyright": "Copyright © 2026 OdooCARE. All rights reserved.",
    "category": "DeveloperTool",
    "shortDescription": "Odoo Module Dependency Analyzer for Community Edition",
    "longDescription": "A desktop tool to analyze Odoo CE module ZIPs — resolve dependency order, detect missing modules, check internal/external dependencies, and catch undeclared Python imports — so you never crash Odoo after installing untested modules.",
    "licenseFile": "../LICENSE",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "languages": ["English"],
        "startMenuFolder": "OdooCARE"
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
